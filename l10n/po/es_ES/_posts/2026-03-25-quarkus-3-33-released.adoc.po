msgstr "link:https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.28[Guía de migración para 3.28]"

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.29[Migration guide for 3.29]"
msgstr "link:https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.29[Guía de migración para 3.29]"

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
msgid "https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.30[Migration guide for 3.30]"
msgstr "link:https://github.com/quarkusio/quarkus/wiki/Migration-Guide-3.30[Guía de migración para 3.30]"

#. type: Plain text
#: _posts/2026-03-25-quarkus-3-33-released.adoc
#, fuzzy
