#. type: Title ##
#: upstream/CLAUDE.md:11
#, no-wrap
msgid "Project Structure"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_posts/` ŌĆö Blog posts (`.adoc`, `.asciidoc`, or `.md` with `YYYY-MM-DD-slug` naming)\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_guides/` ŌĆö Guides (maintained in the main Quarkus repo, do not edit here)\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_layouts/` ŌĆö Jekyll layouts\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_includes/` ŌĆö Jekyll includes and partials\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_data/` ŌĆö YAML data files (`authors.yaml`, events, books)\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_sass/` ŌĆö SCSS stylesheets\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_config.yml` ŌĆö Main Jekyll configuration\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_config_dev.yml` ŌĆö Dev overrides (staging search cluster)\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`_noguides_config.yml` ŌĆö Excludes guides for fast builds\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`jekyll-container/` ŌĆö Dockerfile and entrypoint for containerized Jekyll\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:24
#, no-wrap
msgid "`assets/` ŌĆö Static assets (images, JavaScript, CSS)\n"
msgstr ""

#. type: Title ##
#: upstream/CLAUDE.md:25
#, no-wrap
msgid "Blog Post Conventions"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Filename: `YYYY-MM-DD-slug.adoc` (date must match front matter `date`)\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Front matter: `layout: post`, `title`, `date`, `tags`, `synopsis`, `author`\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Author must be defined in `_data/authors.yaml`\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Tags: lowercase, space-separated\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Permalink pattern: `/blog/:title/`\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Images: store in `assets/images/posts/<slug>/`, reference with `:imagesdir:`\n"
msgstr ""

#. type: Bullet: '- '
#: upstream/CLAUDE.md:33
#, no-wrap
msgid "Preview locally: `just blog-preview` (auto-detects changes, opens browser)\n"
msgstr ""
