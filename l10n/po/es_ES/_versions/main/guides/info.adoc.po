#, fuzzy
msgid "Application Info Endpoint"
msgstr "Punto final de información de la aplicación"

#. type: Plain text
#: _versions/main/guides/info.adoc
#, fuzzy
msgid "The `quarkus-info` extension exposes an HTTP endpoint at `/q/info` that returns information about the application: build metadata, git commit, Java version, and operating system."
msgstr "La extensión `quarkus-info` expone un punto final HTTP en `/q/info` que devuelve información sobre la aplicación: metadatos de compilación, commit de git, versión de Java y sistema operativo."

